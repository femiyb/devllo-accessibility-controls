#: includes/class-settings.php:484
msgid "Accessibility quick check"
msgstr ""

#: includes/class-settings.php:761
msgid "Text is resizable"
msgstr ""

#: includes/class-settings.php:762
msgid "Check that text can be resized up to 200% without loss of content or functionality."
msgstr ""

#: includes/class-settings.php:766
msgid "Sufficient colour contrast"
msgstr ""

#: includes/class-settings.php:767
msgid "Verify that text and essential UI elements meet at least WCAG AA contrast ratios (4.5:1 for normal text, 3:1 for large text)."
msgstr ""

#: includes/class-settings.php:771
msgid "Colour is not the only visual means of conveying information"
msgstr ""

#: includes/class-settings.php:772
msgid "Ensure information is not conveyed by colour alone — use labels, patterns, or icons alongside colour."
msgstr ""

#: includes/class-settings.php:776
msgid "Images have meaningful alternatives"
msgstr ""

#: includes/class-settings.php:777
msgid "Check that informative images have appropriate alternative text and decorative images are marked accordingly."
msgstr ""

#: includes/class-settings.php:781
msgid "Videos have captions"
msgstr ""

#: includes/class-settings.php:782
msgid "Ensure all pre-recorded video content has accurate captions for users who are deaf or hard of hearing."
msgstr ""

#: includes/class-settings.php:786
msgid "Audio content has transcripts or descriptions"
msgstr ""

#: includes/class-settings.php:787
msgid "Provide transcripts for audio-only content and audio descriptions for video content where visual information is not conveyed in the audio."
msgstr ""

#: includes/class-settings.php:791
msgid "Content reflows at 400% zoom"
msgstr ""

#: includes/class-settings.php:792
msgid "Check that content can be viewed at 400% zoom on a 1280px wide screen without requiring horizontal scrolling."
msgstr ""

#: includes/class-settings.php:798
msgid "All functionality is keyboard accessible"
msgstr ""

#: includes/class-settings.php:799
msgid "Verify that all interactive elements — menus, forms, modals, carousels — can be operated using only a keyboard."
msgstr ""

#: includes/class-settings.php:803
msgid "No keyboard traps"
msgstr ""

#: includes/class-settings.php:804
msgid "Ensure keyboard focus is never trapped in a component — users can always navigate away using the keyboard."
msgstr ""

#: includes/class-settings.php:808
msgid "Skip navigation links are present"
msgstr ""

#: includes/class-settings.php:809
msgid "Provide a skip link at the top of each page so keyboard users can bypass repeated navigation and jump to main content."
msgstr ""

#: includes/class-settings.php:813
msgid "Pages have descriptive titles"
msgstr ""

#: includes/class-settings.php:814
msgid "Ensure every page has a unique, descriptive title that identifies its topic or purpose."
msgstr ""

#: includes/class-settings.php:818
msgid "Visible keyboard focus"
msgstr ""

#: includes/class-settings.php:819
msgid "Ensure keyboard focus is always visible and not removed by custom styles."
msgstr ""

#: includes/class-settings.php:823
msgid "Focus order is logical"
msgstr ""

#: includes/class-settings.php:824
msgid "Verify that the keyboard tab order follows a logical sequence that matches the visual layout of the page."
msgstr ""

#: includes/class-settings.php:828
msgid "Link purpose is clear"
msgstr ""

#: includes/class-settings.php:829
msgid "Ensure link text clearly describes the destination or purpose. Avoid generic text like \"click here\" or \"read more\"."
msgstr ""

#: includes/class-settings.php:833
msgid "No content flashes more than 3 times per second"
msgstr ""

#: includes/class-settings.php:834
msgid "Ensure no content flashes or strobes more than three times per second to avoid triggering seizures."
msgstr ""

#: includes/class-settings.php:838
msgid "Motion is optional and not overwhelming"
msgstr ""

#: includes/class-settings.php:839
msgid "Ensure motion, animations, and auto-playing content are limited, optional, and respect reduced-motion preferences."
msgstr ""

#: includes/class-settings.php:845
msgid "Page language is set"
msgstr ""

#: includes/class-settings.php:846
msgid "Ensure the primary language of each page is identified using the lang attribute on the html element."
msgstr ""

#: includes/class-settings.php:850
msgid "Navigation is consistent across pages"
msgstr ""

#: includes/class-settings.php:851
msgid "Verify that navigation menus, headers, and footers appear in the same location and order across all pages."
msgstr ""

#: includes/class-settings.php:855
msgid "Error messages are descriptive"
msgstr ""

#: includes/class-settings.php:856
msgid "Ensure form errors clearly identify which field has an error and describe what the user needs to do to fix it."
msgstr ""

#: includes/class-settings.php:860
msgid "All form inputs have labels"
msgstr ""

#: includes/class-settings.php:861
msgid "Verify that every form input has a visible label or accessible name so users know what information is required."
msgstr ""

#: includes/class-settings.php:865
msgid "Error prevention for important submissions"
msgstr ""

#: includes/class-settings.php:866
msgid "For forms that submit important data (purchases, legal agreements), provide a way to review, correct, or confirm before final submission."
msgstr ""

#: includes/class-settings.php:872
msgid "HTML markup is valid"
msgstr ""

#: includes/class-settings.php:873
msgid "Check that pages use valid, well-formed HTML with no duplicate IDs or improperly nested elements."
msgstr ""

#: includes/class-settings.php:877
msgid "ARIA is used correctly"
msgstr ""

#: includes/class-settings.php:878
msgid "Ensure ARIA roles, states, and properties are used correctly and only where native HTML cannot provide the same semantics."
msgstr ""

#: includes/class-settings.php:882
msgid "Status messages are programmatically determined"
msgstr ""

#: includes/class-settings.php:883
msgid "Ensure status messages (success, error, loading) are conveyed to assistive technologies without requiring focus, using aria-live regions."
msgstr ""

#: includes/class-settings.php:887
msgid "Interactive elements have accessible names"
msgstr ""

#: includes/class-settings.php:888
msgid "Verify that all buttons, links, and form controls have accessible names that clearly describe their purpose to assistive technologies."
msgstr ""

